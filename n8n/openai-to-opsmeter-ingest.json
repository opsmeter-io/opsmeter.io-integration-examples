          "options": {
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "status-402",
              "leftValue": "={{$json.statusCode}}",
              "operator": {
                "type": "number",
                "operation": "equal"
              },
              "rightValue": 402
            },
            {
              "id": "reason-plan-limit",
              "leftValue": "={{$json.body.reason}}",
              "operator": {
                "type": "string",
                "operation": "equals"
              },
              "rightValue": "plan_limit_reached"
