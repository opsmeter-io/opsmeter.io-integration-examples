        "url": "https://api.openai.com/v1/responses",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.OPENAI_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"input\": \"Summarize this invoice and list risky line items.\"\n}",
        "options": {}
      },
      "id": "openai-response-call",
      "name": "OpenAI Response Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        420,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $json;\nconst usage = response.usage || {};\nconst inputTokens = usage.input_tokens ?? usage.prompt_tokens ?? 0;\nconst outputTokens = usage.output_tokens ?? usage.completion_tokens ?? 0;\nconst totalTokens = usage.total_tokens ?? (inputTokens + outputTokens);\n\nreturn [{\n  json: {\n    externalRequestId: $execution.id,\n    provider: 'openai',\n    model: response.model || 'gpt-4o-mini',\n    promptVersion: 'n8n_demo_v1',\n    endpointTag: 'n8n.workflow.summary',\n    inputTokens,\n    outputTokens,\n    totalTokens,\n    latencyMs: 0,\n    status: 'success',\n    dataMode: 'real',\n    environment: 'prod'\n  }\n}];"
      },
      "id": "map-usage-to-ingest-payload",
      "name": "Map Usage To Ingest Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        320
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.opsmeter.io/v1/ingest/llm-request",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "={{$env.OPSMETER_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{$json}}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "send-ingest",
